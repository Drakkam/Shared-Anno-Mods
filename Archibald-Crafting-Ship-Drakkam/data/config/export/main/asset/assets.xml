<ModOps>
<!-- Changing Diving Bell Item Category icon to a generic one-->
  <ModOp Type="merge" GUID="113880" Path="/Values/Standard">
          <IconFilename>data/ui/2kimages/main/icons/icon_prestige.png</IconFilename>
  </ModOp>

<!-- Adding Crafting UI and properties to Archibalds Clipper-->

  <ModOp Type="addNextSibling" GUID='500477'>
    <Asset>
		<Template>InfoLayerIcon</Template>
		<Values>
			<Standard>
				<GUID>1555000752</GUID>
				<Name>Craft</Name>
			</Standard>
			<InfoLayerIcon>
				<Config>data/graphics/ui/infolayer3d/exclamation_mark_blue.cfg</Config>
				<PopupDelay>0</PopupDelay>
				<ShowInCreativeMode>1</ShowInCreativeMode>
			</InfoLayerIcon>
		</Values>
	</Asset>
  </ModOp>
  <ModOp Type="merge" GUID='101152' Path="/Values">
    <Selection>
			<GUIType>TraderOldNate</GUIType>
			<OnSelection>
				<IsBaseAutoCreateAsset>1</IsBaseAutoCreateAsset>
				<Values>
					<ActionList/>
				</Values>
			</OnSelection>
			<InteractionDistance>20</InteractionDistance>
			<Colors>
				<SelectionColorType>PropertySelectionColor</SelectionColorType>
				<SelectionColor>-337045</SelectionColor>
				<WeakSelectionColorType>NoColor</WeakSelectionColorType>
			</Colors>
		</Selection>
		<Infolayer>
			<DefaultInfoLayer>1555000752</DefaultInfoLayer>
		</Infolayer>
  </ModOp>
  <ModOp Type="merge" GUID='101152'>
    <Template>ItemCrafterBuilding</Template>
  </ModOp>

<!-- Adding Craftable items to Archibalds Profile-->
<ModOp Type="Merge" GUID='45' Path="/Values">
  <ItemCrafter>
			<CraftableItemsInRegion>
				<Moderate>
					<CraftableItems>
					</CraftableItems>
				</Moderate>
			</CraftableItemsInRegion>
		</ItemCrafter>
  </ModOp>
</ModOps>